# 排除一切非软件本体的文件
.git
.gitignore
.agents
agent-skills
*.vsix
.DS_Store
PUBLISHING.md
SKILL.md
test-timeout.js

# 排除 node_modules 中的无用文件
node_modules/@types
node_modules/typescript
node_modules/**/README.md
node_modules/**/CHANGELOG.md
node_modules/**/LICENSE
node_modules/**/LICENSE.md
node_modules/**/.gitkeep
node_modules/**/*.d.ts
node_modules/**/*.map

# 排除 .gitkeep 占位文件
**/.gitkeep
